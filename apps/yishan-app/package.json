{
  "name": "yishan-app",
  "version": "0.1.0",
  "private": true,
  "description": "移山小程序 (Taro 4 + React 18) — 钉钉/飞书风 ToB 移动端",
  "scripts": {
    "dev:weapp": "NODE_ENV=development taro build --type weapp --watch",
    "dev:h5": "NODE_ENV=development taro build --type h5 --watch",
    "dev:swan": "NODE_ENV=development taro build --type swan --watch",
    "dev:alipay": "NODE_ENV=development taro build --type alipay --watch",
    "dev:tt": "NODE_ENV=development taro build --type tt --watch",
    "build:weapp": "taro build --type weapp",
    "build:h5": "taro build --type h5",
    "build:swan": "taro build --type swan",
    "build:alipay": "taro build --type alipay",
    "build:tt": "taro build --type tt",
    "lint": "biome lint . && tsc --noEmit",
    "biome:lint": "biome lint .",
    "tsc": "tsc --noEmit",
    "clean": "rimraf dist node_modules/.cache"
  },
  "dependencies": {
    "@tarojs/components": "^4.0.0",
    "@tarojs/helper": "^4.0.0",
    "@tarojs/plugin-framework-react": "^4.0.0",
    "@tarojs/plugin-html": "^4.0.0",
    "@tarojs/plugin-platform-alipay": "^4.0.0",
    "@tarojs/plugin-platform-h5": "^4.0.0",
    "@tarojs/plugin-platform-jd": "^4.0.0",
    "@tarojs/plugin-platform-qq": "^4.0.0",
    "@tarojs/plugin-platform-swan": "^4.0.0",
    "@tarojs/plugin-platform-tt": "^4.0.0",
    "@tarojs/plugin-platform-weapp": "^4.0.0",
    "@tarojs/react": "file:./scripts/tarojs-react-shim",
    "@tarojs/runtime": "^4.0.0",
    "@tarojs/shared": "^4.0.0",
    "@tarojs/taro": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.6.2",
    "@tarojs/cli": "^4.0.0",
    "@tarojs/components-react": "^4.0.0",
    "@tarojs/webpack5-runner": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/webpack-env": "^1.18.5",
    "babel-preset-taro": "^4.0.0",
    "rimraf": "^6.0.1",
    "typescript": "~5.4.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
