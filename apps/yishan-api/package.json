{
  "name": "yishan-api",
  "version": "1.0.0",
  "description": "This project was bootstrapped with Fastify-CLI.",
  "type": "commonjs",
  "main": "app.js",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run test/integration",
    "start": "npm run build:ts && fastify start -l info dist/app.js",
    "build:ts": "tsc && tsc-alias",
    "watch:ts": "concurrently -k \"tsc -w\" \"tsc-alias -w\"",
    "dev": "NODE_ENV=development npm run build:ts && concurrently -k -p \"[{name}]\" -n \"TypeScript,App\" -c \"yellow.bold,cyan.bold\" \"npm:watch:ts\" \"npm:dev:start\"",
    "dev:start": "NODE_ENV=development fastify start --ignore-watch='public/**' --ignore-watch=.ts$ -w -l info -P dist/app.js",
    "db:generate": "node scripts/generate-drizzle-schema.mjs",
    "db:generate:test": "node scripts/test-generator.mjs",
    "db:migrate": "npm run build:ts && node dist/scripts/migrate.js",
    "db:init": "npm run db:generate && npm run db:migrate",
    "db:seed": "npm run build:ts && node dist/scripts/seed.js",
    "db:seed:regions": "npm run build:ts && node dist/scripts/import-regions.js",
    "db:reseed": "npm run db:migrate && npm run db:seed",
    "db:reset": "npm run build:ts && node dist/scripts/reset.js",
    "cli": "node dist/cli/index.js",
    "cli:dev": "ts-node src/cli/index.ts"
  },
  "bin": {
    "yishan-api-cli": "dist/cli/index.js"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@fastify/autoload": "^6.0.0",
    "@fastify/cookie": "^11.1.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.3.0",
    "@fastify/redis": "^7.0.2",
    "@fastify/sensible": "^6.0.0",
    "@fastify/static": "^8.0.0",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@sinclair/typebox": "^0.34.41",
    "close-with-grace": "^2.3.0",
    "dayjs": "^1.11.18",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.7",
    "fastify": "^5.0.0",
    "fastify-cli": "^7.4.0",
    "fastify-plugin": "^5.0.0",
    "mysql2": "^3.15.3",
    "qiniu": "^7.14.0",
    "sanitize-html": "^2.17.6"
  },
  "devDependencies": {
    "@types/node": "^22.1.0",
    "@types/sanitize-html": "^2.16.1",
    "c8": "^10.1.2",
    "concurrently": "^9.0.0",
    "drizzle-kit": "^0.31.7",
    "fastify-tsconfig": "^3.0.0",
    "ts-node": "^10.4.0",
    "tsc-alias": "^1.8.16",
    "typescript": "~5.8.2",
    "vitest": "^4.0.7"
  }
}
