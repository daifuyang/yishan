{
  "name": "yishan-admin",
  "version": "6.0.0",
  "private": true,
  "description": "An out-of-box UI solution for enterprise applications",
  "repository": "https://github.com/zerocmf/yishan.git",
  "scripts": {
    "analyze": "cross-env ANALYZE=1 max build",
    "build": "max build",
    "deploy": "npm run build && npm run gh-pages",
    "dev": "npm run start:dev",
    "gh-pages": "gh-pages -d dist",
    "i18n-remove": "pro i18n-remove --locale=zh-CN --write",
    "prelint": "max setup",
    "prebuild": "max setup",
    "jest": "jest",
    "lint": "npx @biomejs/biome lint && tsc --noEmit",
    "lint-staged": "lint-staged",
    "biome:lint": "npx @biomejs/biome lint",
    "openapi": "max openapi",
    "prepare": "husky",
    "preview": "npm run build && max preview --port 8000",
    "record": "cross-env NODE_ENV=development UMI_ENV=test max record --scene=login",
    "serve": "umi-serve",
    "start": "cross-env UMI_ENV=dev max dev",
    "start:dev": "cross-env UMI_ENV=dev MOCK=none max dev",
    "start:no-mock": "cross-env MOCK=none max dev",
    "start:pre": "cross-env UMI_ENV=pre MOCK=none max dev",
    "start:test": "cross-env UMI_ENV=test MOCK=none max dev",
    "test": "jest",
    "test:coverage": "npm run jest -- --coverage",
    "test:update": "npm run jest -- -u",
    "tsc": "tsc --noEmit"
  },
  "browserslist": [
    "defaults"
  ],
  "dependencies": {
    "@ant-design/icons": "^6.2.3",
    "@ant-design/pro-components": "^3.1.12-0",
    "@json-render/core": "^0.3.0",
    "@json-render/react": "^0.2.0",
    
    "antd": "^6.4.3",
    "antd-style": "^4.1.0",
    "classnames": "^2.5.1",
    "dayjs": "^1.11.20",
    "lucide-react": "^0.548.0",
    "query-string": "^9.1.0",
    "rc-menu": "^9.16.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-easy-crop": "^6.2.2",
    "swagger-ui-dist": "^5.32.5",
    "yishan-tiptap": "workspace:^"
  },
  "devDependencies": {
    "@ant-design/pro-cli": "^3.3.0",
    "@biomejs/biome": "^2.4.13",
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-helmet": "^6.1.11",
    "@umijs/lint": "^4.6.51",
    "@umijs/max": "^4.6.51",
    "cross-env": "^10.1.0",
    "express": "^5.2.1",
    "gh-pages": "^6.3.0",
    "husky": "^9.1.7",
    "jest": "^30.4.1",
    "jest-environment-jsdom": "^30.4.1",
    "lint-staged": "^17.0.2",
    "mockjs": "^1.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "umi-presets-pro": "^2.0.3",
    "umi-serve": "^1.9.11"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "create-umi": {
    "ignoreScript": [
      "docker*",
      "functions*",
      "site",
      "generateMock",
      "netlify*",
      "serverless"
    ],
    "ignore": [
      ".dockerignore",
      ".git",
      ".github",
      ".gitpod.yml",
      "CODE_OF_CONDUCT.md",
      "Dockerfile",
      "Dockerfile.*",
      "lambda",
      "LICENSE",
      "netlify.toml",
      "README.*.md",
      "azure-pipelines.yml",
      "docker",
      "CNAME",
      "create-umi"
    ]
  }
}
