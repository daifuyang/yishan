{
  "name": "@zerocmf/yishan",
  "version": "1.0.0",
  "description": "移山通用管理系统 - 基于 React/Ant Design Pro、Fastify、Docusaurus 的 monorepo 解决方案",
  "private": true,
  "scripts": {
    "build": "pnpm --filter yishan-admin build && pnpm --filter yishan-docs build && pnpm --filter yishan-tiptap build",
    "dev:admin": "pnpm --filter yishan-admin dev",
    "dev:api": "pnpm --filter yishan-api dev",
    "build:admin": "pnpm --filter yishan-admin build",
    "preview:admin": "pnpm --filter yishan-admin preview",
    "build:api": "pnpm --filter yishan-api build:ts",
    "dev:docs": "pnpm --filter yishan-docs start",
    "build:docs": "pnpm --filter yishan-docs build",
    "preview:docs": "pnpm --filter yishan-docs serve",
    "dev:tiptap": "pnpm --filter yishan-tiptap dev",
    "build:tiptap": "pnpm --filter yishan-tiptap build",
    "start:api": "pnpm --filter yishan-api start",
    "db:generate": "pnpm --filter yishan-api db:generate",
    "db:init": "pnpm --filter yishan-api db:init",
    "db:seed": "pnpm --filter yishan-api db:seed",
    "db:reset": "pnpm --filter yishan-api db:reset",
    "lint": "pnpm --filter yishan-admin lint && pnpm --filter yishan-docs typecheck",
    "lint:admin": "pnpm --filter yishan-admin lint",
    "lint:docs": "pnpm --filter yishan-docs typecheck",
    "clean": "pnpm -r exec -- node -e \"['dist','.next','node_modules/.cache'].forEach(p=>{try{require('fs').rmSync(p,{recursive:true,force:true})}catch{}})\"",
    "type-check": "pnpm --filter yishan-admin tsc && pnpm --filter yishan-docs typecheck",
    "test": "pnpm --filter yishan-admin test && pnpm --filter yishan-api test"
  },
  "keywords": [
    "react",
    "ant-design-pro",
    "umi",
    "fastify",
    "prisma",
    "docusaurus",
    "monorepo",
    "admin-template"
  ],
  "author": "yishan",
  "license": "MIT",
  "packageManager": "pnpm@8.15.9",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  }
}
